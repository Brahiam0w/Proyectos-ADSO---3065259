# Configuración del Servidor
PORT=3000

# Base de Datos (MongoDB Atlas para producción)
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/numerologia

# Seguridad
JWT_SECRET=tu_secreto_super_seguro

# IA (Gemini API)
GEMINI_API_KEY=tu_api_key_de_google_gemini

# Correo Electrónico (Para envío de lecturas y recuperación)
EMAIL_SERVICE=gmail
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu-app-password-de-gmail

# Mercado Pago (Para suscripciones y pagos)
MP_ACCESS_TOKEN=tu_access_token_de_mercado_pago

# URLs de Referencia (Para CORS y Redirecciones)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
# WEBHOOK_URL=https://tu-api.onrender.com/api/pagos/webhook

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Base de Datos (MongoDB)
MONGO_URI=mongodb://localhost:27017/requerimientoBot

# Seguridad y Cifrado
# ENCRYPTION_KEY debe ser de exactamente 32 caracteres para AES-256-GCM
ENCRYPTION_KEY=tu_clave_secreta_de_32_caracteres_
JWT_SECRET=tu_secreto_para_tokens_jwt_seguro

# Configuración del Bot (Opcional)
SENA_PORTAL_URL=https://ejemplo.sena.edu.co/certificados
